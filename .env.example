# ============================================================
# Auvvo AI — Exemplo de Configuração (.env.example)
# Copie para .env e preencha os valores reais.
# NUNCA versione o arquivo .env com dados reais!
# ============================================================

# ============================================================
# BANCO DE DADOS
# ============================================================
DB_HOST=212.85.3.45
DB_NAME=auvvo_db
DB_USER=auvvo_user
DB_PASS=sua_senha_aqui

# ============================================================
# AMBIENTE
# ============================================================
APP_ENV=production
APP_BASE_URL=https://seu-dominio.com

# ============================================================
# EVOLUTION API (WhatsApp)
# Docs: https://docs.evolutionfoundation.com.br/evolution-go
# ============================================================
EVOLUTION_API_URL=https://sua-evolution.exemplo.com
EVOLUTION_API_KEY=sua_chave_evolution_aqui

# Segredo do webhook (openssl rand -hex 32)
WEBHOOK_SECRET=

# ============================================================
# OPENROUTER — Motor de IA principal
# Docs: https://openrouter.ai/docs/quickstart
# Exemplos de modelo: openrouter/openai/gpt-4o-mini
#                     openrouter/google/gemini-flash-1.5
#                     openrouter/anthropic/claude-3-haiku
# ============================================================
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_MODEL=openrouter/openai/gpt-4o-mini

# ============================================================
# GOOGLE GEMINI (opcional)
# ============================================================
# GEMINI_API_KEY=AIza...

# ============================================================
# GOOGLE CALENDAR (OAuth 2.0)
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Redirect adicional no Google Cloud para Sheets:
# GOOGLE_SHEETS_REDIRECT_URI=https://seu-dominio.com/backend/google_sheets_callback.php

# ============================================================
# E-MAIL TRANSACIONAL
# ============================================================
SUPPORT_EMAIL=contato@seu-dominio.com
MAIL_FROM_EMAIL=contato@seu-dominio.com
MAIL_FROM_NAME=SuaEmpresa
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=contato@seu-dominio.com
SMTP_PASS=sua_senha_smtp

# ============================================================
# GATEWAY DE PAGAMENTO
# Valores: abacatepay | stripe
# ============================================================
PAYMENT_GATEWAY=abacatepay

# AbacatePay
ABACATEPAY_API_KEY=abc_prod_...
ABACATEPAY_PRODUCT_MENSAL=prod_...
ABACATEPAY_PRODUCT_ANUAL=prod_...
ABACATEPAY_WEBHOOK_QUERY_SECRET=seu_token_webhook

# Stripe (descomente se usar)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_MENSAL=
# STRIPE_PRICE_ANUAL=

# Cérebro: function calling nativo na API (além de [[AUVO_ACTIONS]] no texto)
# BRAIN_NATIVE_TOOLS=1

# ============================================================
# FILA IA (produção: queue + auvvo-worker Node)
# ============================================================
# inline = IA no webhook; queue = fila MySQL + auvvo-worker Node
WEBHOOK_AI_MODE=queue
WEBHOOK_DEBOUNCE_SEC=4
WORKER_AI_MAX_ATTEMPTS=3
WORKER_POLL_MS=300
RATE_LIMIT_MIN_INTERVAL_SEC=2
RATE_LIMIT_PER_PEER_MIN=30
RATE_LIMIT_PER_AGENT_MIN=60
ANTI_BOT_LOOP_MAX_AI_STREAK=8
CONTEXT_USE_SUMMARY=1
CONTEXT_SUMMARIZE_AFTER_TURNS=15
CAMPAIGN_MSGS_PER_MINUTE=12

# ============================================================
# LOGGING / DIAGNÓSTICO
# ============================================================
WEBHOOK_TRACE_LOG=1
# WEBHOOK_DISABLE_LITESPEED_CLI=0
# WEBHOOK_AI_MODE=inline  # apenas com APP_ENV=development